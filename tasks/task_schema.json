{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Intent-Forge Task Definition",
  "type": "object",
  "required": ["agent", "task", "input", "output", "max_turns", "skills", "depends_on"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": ["orchestrator", "researcher", "generator", "reviewer"]
    },
    "task": {
      "type": "string"
    },
    "input": {
      "type": "string"
    },
    "output": {
      "type": "string"
    },
    "max_turns": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "default": 3
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 4
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["orchestrator", "researcher", "generator", "reviewer"]
      }
    }
  },
  "additionalProperties": false
}
