{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Intent-Forge Task Definition",
  "type": "object",
  "required": ["agent", "input", "output", "max_turns"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": ["orchestrator", "researcher", "generator", "reviewer"]
    },
    "input": {
      "type": "string",
      "description": "What this agent receives from upstream"
    },
    "output": {
      "type": "string",
      "description": "What this agent produces for downstream"
    },
    "max_turns": {
      "type": "integer",
      "maximum": 3,
      "default": 3
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 4
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Agent names this task depends on"
    },
    "error_handling": {
      "type": "string",
      "default": "log to state/session.json errors[] and continue"
    }
  }
}
